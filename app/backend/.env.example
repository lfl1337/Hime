# Hime backend — environment variables
# Copy this file to .env (never commit .env to git)
# API_KEY is generated automatically on first run if left empty.

# Local API key — guards our FastAPI endpoints; generated on first run
API_KEY=

# Preferred backend port (default 8000). If this port is busy at startup,
# run.py scans upward automatically. The chosen port is written to .runtime_port.
PORT=8000

# Local inference server base URL (no path suffix, the client appends /chat/completions etc.)
# llama.cpp default: http://127.0.0.1:8080/v1
# vllm default:      http://127.0.0.1:8000/v1  (use a different port if FastAPI is on 8000)
INFERENCE_URL=http://127.0.0.1:8080/v1

# Model name as expected by the inference server (must match what was loaded)
# Examples: qwen2.5-14b-instruct, qwen2.5-32b-instruct, qwen2.5-72b-instruct
INFERENCE_MODEL=qwen2.5-14b-instruct

# SQLite database path (relative to backend/)
DB_URL=sqlite+aiosqlite:///./hime.db

# Audit log path (relative to backend/)
AUDIT_LOG_PATH=logs/audit.log

# Rate limit: max requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# ---------------------------------------------------------------------------
# Multi-stage pipeline model endpoints
# Each model runs on its own local inference server instance.
# ---------------------------------------------------------------------------

# Stage 1 — three parallel translators
HIME_GEMMA_URL=http://127.0.0.1:8001/v1
HIME_GEMMA_MODEL=hime-gemma
HIME_DEEPSEEK_URL=http://127.0.0.1:8002/v1
HIME_DEEPSEEK_MODEL=hime-deepseek
HIME_QWEN32B_URL=http://127.0.0.1:8003/v1
HIME_QWEN32B_MODEL=hime-qwen32b

# Consensus merger (defaults to the same server as qwen32b)
HIME_MERGER_URL=http://127.0.0.1:8003/v1
HIME_MERGER_MODEL=hime-qwen32b

# Stage 2 — 72B refinement
HIME_QWEN72B_URL=http://127.0.0.1:8004/v1
HIME_QWEN72B_MODEL=hime-qwen72b

# Stage 3 — 14B final polish
HIME_QWEN14B_URL=http://127.0.0.1:8005/v1
HIME_QWEN14B_MODEL=hime-qwen14b

# Training / fine-tuning paths
MODELS_BASE_PATH=C:\Projekte\Hime\modelle
LORA_PATH=C:\Projekte\Hime\modelle\lora\Qwen2.5-32B-Instruct
TRAINING_LOG_PATH=C:\Projekte\Hime\app\backend\logs\training
SCRIPTS_PATH=C:\Projekte\Hime\scripts
